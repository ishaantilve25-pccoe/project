import sympy as sp

def find_maxima_minima():
    # Define symbolic variables
    x, y = sp.symbols('x y', real=True)
    
    # Get user input for the function
    f_input = input("Please provide the given function (use Python syntax like x**2 + y**2):\n")
    
    try:
        # Convert string input to a SymPy expression
        f = sp.sympify(f_input)
    except Exception as e:
        print(f"Error parsing function: {e}")
        return

    # First-order partial derivatives
    f_x = sp.diff(f, x)
    f_y = sp.diff(f, y)

    # Set up equations for stationary points (f_x = 0, f_y = 0)
    eq1 = sp.Eq(f_x, 0)
    eq2 = sp.Eq(f_y, 0)

    # Solve the system of equations for real solutions
    solutions = sp.solve([eq1, eq2], (x, y), dict=True)

    print("\nAll possible stationary points are:")
    # Filter for real solutions and print them
    real_solutions = []
    for i, sol in enumerate(solutions, start=1):
        # Ensure the solution values are real
        if sol[x].is_real and sol[y].is_real:
            real_solutions.append(sol)
            print(f"{i}) ({sol[x]}, {sol[y]})")

    if not real_solutions:
        print("No real stationary points found.")
        return

    # Second-order partial derivatives (Hessian components)
    # Note: in your MATLAB code, 't' was diff(f_y, x) which is f_yx, and 's' was diff(f_y, y) which is f_yy.
    # Standard notation: r = f_xx, s = f_xy, t = f_yy. 
    # The discriminant formula is d = r*t - s^2.
    r_expr = sp.diff(f_x, x)
    s_expr = sp.diff(f_x, y)  # f_xy
    t_expr = sp.diff(f_y, y)  # f_yy

    # Discriminant (D = f_xx * f_yy - (f_xy)^2)
    d_expr = r_expr * t_expr - s_expr**2

    print("\n--- Classification of Stationary Points ---")
    for i, sol in enumerate(real_solutions, start=1):
        # Evaluate r and d at the specific stationary point
        r_val = r_expr.subs({x: sol[x], y: sol[y]})
        d_val = d_expr.subs({x: sol[x], y: sol[y]})
        
        print(f"\nPoint {i}: ({sol[x]}, {sol[y]})")
        print(f"  D = {d_val}, f_xx = {r_val}")
        
        # Classification logic
        if d_val > 0:
            if r_val > 0:
                print("  Conclusion: Local Minimum")
            elif r_val < 0:
                print("  Conclusion: Local Maximum")
            else:
                print("  Conclusion: Second derivative test is inconclusive")
        elif d_val < 0:
            print("  Conclusion: Saddle Point")
        else:
            print("  Conclusion: The test is inconclusive (D = 0)")

if __name__ == "__main__":
    find_maxima_minima()
